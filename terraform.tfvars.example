# ==============================================================================
# IBM Cloud VPC-Power VS Unified Network Configuration
# ==============================================================================
# This example shows the required variables for deploying the unified network
# infrastructure that connects IBM Cloud VPC (x86) and Power Virtual Server.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp terraform.tfvars.example terraform.tfvars
# 2. Edit terraform.tfvars with your actual values
# 3. Never commit terraform.tfvars to Git (it's in .gitignore)
# ==============================================================================

# ==============================================================================
# IBM Cloud Authentication
# ==============================================================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
# Click "Create" and copy the key immediately (you won't see it again)
ibmcloud_api_key = "YOUR_IBM_CLOUD_API_KEY_HERE"

# ==============================================================================
# Project Configuration
# ==============================================================================
# Project name - used as prefix for all resources
# Example: "mmn-vpc-pvs-nat" creates resources like "mmn-vpc-pvs-nat-vpc"
project_name = "your-project-name"

# IBM Cloud region for VPC resources
# Options: us-south, us-east, eu-gb, eu-de, jp-tok, au-syd
region = "us-east"

# Availability zone within the region
# Must match the region (e.g., us-east-1, us-east-2, us-east-3)
zone = "us-east-1"

# Resource group ID
# Find yours: ibmcloud resource groups
# Or use: ibmcloud resource group <group-name> --id
resource_group_id = "YOUR_RESOURCE_GROUP_ID"

# ==============================================================================
# SSH Key Configuration
# ==============================================================================
# VPC SSH key name (must already exist in IBM Cloud VPC)
# Create: ibmcloud is key-create <name> @~/.ssh/id_rsa.pub
# List: ibmcloud is keys
vpc_ssh_key_name = "your-vpc-ssh-key-name"

# Secondary SSH key name (optional, for additional access)
secondary_ssh_key_name = "your-secondary-ssh-key-name"

# Power VS SSH key name (will be created in Power VS workspace)
# This is just a name, the actual key content is in murali-key-n1-rsa.pub
power_vs_ssh_key_name = "your-power-vs-ssh-key-name"

# ==============================================================================
# Power Virtual Server Configuration
# ==============================================================================
# Power VS zone/datacenter
# Options: wdc06, wdc07 (Washington DC), dal12, dal13 (Dallas), 
#          lon04, lon06 (London), tok04 (Tokyo), syd04, syd05 (Sydney)
# Must be in same region as VPC for Transit Gateway connectivity
power_vs_zone = "wdc06"

# ==============================================================================
# Network Configuration (Usually no changes needed)
# ==============================================================================
# VPC subnet CIDR - unified addressing space
# Default: 10.14.105.0/24 (supports 254 hosts)
# vpc_subnet_cidr = "10.14.105.0/24"

# Power VS network CIDR - internal Power VS addressing
# Default: 192.168.1.0/24
# power_vs_network_cidr = "192.168.1.0/24"

# ==============================================================================
# Resource Sizing (Optional - defaults are set)
# ==============================================================================
# VPC VSI profile (x86 instances)
# Default: cx2-2x4 (2 vCPUs, 4GB RAM)
# Options: cx2-2x4, cx2-4x8, cx2-8x16, etc.
# vsi_profile = "cx2-2x4"

# Power VS LPAR configuration
# Default: s922, shared, 0.25 cores, 2GB RAM, tier3 storage
# power_vs_sys_type = "s922"
# power_vs_proc_type = "shared"
# power_vs_processors = 0.25
# power_vs_memory = 2
# power_vs_storage_type = "tier3"

# ==============================================================================
# Example Configurations
# ==============================================================================

# MINIMAL SETUP (Cost-Optimized for Testing):
# project_name = "test-vpc-pvs"
# region = "us-east"
# zone = "us-east-1"
# power_vs_zone = "wdc06"
# vpc_ssh_key_name = "my-test-key"
# power_vs_ssh_key_name = "my-power-key"

# PRODUCTION SETUP (High Availability):
# project_name = "prod-vpc-pvs"
# region = "us-east"
# zone = "us-east-1"
# power_vs_zone = "wdc06"
# vsi_profile = "cx2-4x8"
# power_vs_processors = 1.0
# power_vs_memory = 8
# power_vs_storage_type = "tier1"

# ==============================================================================
# What Gets Created
# ==============================================================================
# VPC Infrastructure:
#   - VPC with subnet (10.14.105.0/24)
#   - 3 Ubuntu VSIs (including NAT Gateway at 10.14.105.254)
#   - 1 Windows VSI
#   - Security groups and routing tables
#   - Public gateway and floating IPs
#
# Power VS Infrastructure:
#   - Power VS workspace
#   - Private network (192.168.1.0/24)
#   - 3 LPARs: CentOS, RHEL 9, RHEL 8
#   - Secondary IPs for unified addressing
#   - Power VS routes for LPAR-to-LPAR communication
#
# Connectivity:
#   - Transit Gateway connecting VPC and Power VS
#   - NAT Gateway for address translation
#   - VPC custom routes for unified subnet
#
# Total Resources: ~41 resources
# Estimated Cost: ~$200-300/month (varies by region and usage)
# ==============================================================================